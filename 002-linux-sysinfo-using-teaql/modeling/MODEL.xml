<root alias_model_name="linux_system_info"
      chinese_name="Linux系统信息"
      english_name="Linux System Info"
      name="linux-system-info"
      cfg_mask_china_mobile="false"
      data_service="sqlite"
      org="doublechaintech"
      version="0.1.0"
      _module_key="root">

  <system_info _name="System Info"
               _module="System"
               _module_key="system"
               hostname="localhost"
               cpu_count="16"
               memory_total_bytes="85899345920"
               memory_available_bytes="85899345920"
               load_avg_1="1.5"
               load_avg_5="1.2"
               load_avg_15="1.0"
               uptime_seconds="3600.0"
               create_time="createTime()"
               update_time="updateTime()"/>

  <process _name="Process"
           _module="System"
           _module_key="system"
           pid="1000"
           name="bash"
           state="S"
           ppid="1"
           cmdline="/bin/bash"
           thread_count="1"
           memory_rss_kb="8589934592"
           memory_vms_kb="8589934592"
           cpu_user_ticks="8589934592"
           cpu_system_ticks="8589934592"
           system_info="system_info()"
           create_time="createTime()"
           update_time="updateTime()"/>

  <thread _name="Thread"
          _module="System"
          _module_key="system"
          tid="1001"
          name="bash"
          state="S"
          process_pid="1000"
          cpu_user_ticks="8589934592"
          cpu_system_ticks="8589934592"
          process="process()"
          create_time="createTime()"
          update_time="updateTime()"/>

</root>
